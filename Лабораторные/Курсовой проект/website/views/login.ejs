<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link class="site-icon" rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238e7554'%3E%3Cpath d='M19.5 6h-15A2.5 2.5 0 002 8.5v7A2.5 2.5 0 004.5 18h15a2.5 2.5 0 002.5-2.5v-7A2.5 2.5 0 0019.5 6zM8 13H6v-2h2v2zm5-1.5a1.5 1.5 0 11-1.5-1.5 1.5 1.5 0 011.5 1.5zm5 2a1.5 1.5 0 111.5-1.5 1.5 1.5 0 01-1.5 1.5z'/%3E%3C/svg%3E" />
    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <script>

        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
                document.addEventListener('DOMContentLoaded', () => {
                    document.body.classList.add('dark-theme');
                });
            }
        })();
    </script>
    <style>
        .auth-container {
            display: flex;
            flex-direction: row;
            align-items: stretch;
            justify-content: center;
            gap: 28px;
            max-width: 860px;
            width: 100%;
            margin: 60px auto;
        }

        .auth-overlay-card {
            margin: 0 !important;
            flex: 1.1;
        }

        .auth-info-card {
            flex: 0.9;
            background: var(--bg-card);
            border: 1px solid var(--border-strong);
            border-radius: var(--radius-sm);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.03);
            position: relative;
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-left: 3px solid var(--accent);
            transition: var(--transition-smooth);
        }

        .auth-info-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
            box-shadow: 0 24px 68px rgba(0, 0, 0, 0.05);
        }

        .auth-info-header {
            margin-bottom: 20px;
        }

        .auth-info-title {
            font-family: var(--font-display);
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--accent);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.3px;
        }

        .auth-info-title svg {
            color: var(--accent);
            flex-shrink: 0;
        }

        .auth-info-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.65;
        }

        .auth-info-text p {
            margin-bottom: 12px;
        }

        .auth-info-text p:last-child {
            margin-bottom: 0;
        }

        .demo-credentials {
            background: var(--bg-panel);
            border: 1px solid var(--border-regular);
            border-radius: var(--radius-sm);
            padding: 16px;
            margin: 20px 0;
        }

        .credential-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-subtle);
        }

        .credential-row:last-child {
            border-bottom: none;
        }

        .credential-label {
            font-size: 0.72rem;
            color: var(--text-tertiary);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .credential-value {
            font-family: var(--font-mono);
            font-weight: 700;
            color: var(--accent);
            font-size: 0.85rem;
            background: rgba(197, 168, 128, 0.06);
            padding: 3px 8px;
            border-radius: 2px;
            border: 1px dashed var(--accent-border);
        }

        .btn-autofill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 12px 20px;
            font-family: var(--font-sans);
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: transparent;
            color: var(--accent);
            border: 1px dashed var(--accent);
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: var(--transition-fast);
            margin-top: auto;
        }

        .btn-autofill:hover {
            background: var(--accent-light);
            border-style: solid;
            color: var(--accent);
        }

        /* Responsive styling */
        @media (max-width: 860px) {
            .auth-container {
                flex-direction: column;
                align-items: center;
                padding: 0 20px;
                gap: 24px;
                margin: 40px auto;
            }

            .auth-overlay-card, .auth-info-card {
                max-width: 420px;
                width: 100%;
                flex: none;
            }

            .auth-info-card {
                padding: 36px 32px;
            }
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="logo-section">
                <h1>Игровой<span>Атлас</span></h1>
                <p>Справочник лучших видеоигр</p>
            </div>

            <nav class="nav-menu">
                <a href="/" class="nav-link">Главная</a>
                <% if (user) { %>
                    <a href="/data" class="nav-link">Каталог</a>
                    <a href="/profile" class="nav-link">Профиль</a>
                <% } %>
            </nav>

            <div class="user-section">

                <button class="theme-toggle-btn" id="themeToggleBtn" title="Переключить тему">

                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>

                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m8.97-8.97h-2.25C18.18 12 18 11.82 18 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zM5.625 12H3.375C3.18 12 3 11.82 3 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zm12.06-6.435l-1.59 1.59m-9.18 9.18l-1.59 1.59m12.36 0l-1.59-1.59m-9.18-9.18l-1.59-1.59M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z" />
                    </svg>
                </button>

                <a href="/login" class="nav-link" style="color: var(--accent); border-bottom: 2px solid var(--accent); border-radius: 0;">Войти</a>
                <a href="/register" class="nav-link btn-gold">Регистрация</a>
            </div>
        </header>

        <main class="main-content">
            <div class="auth-container">
                <div class="auth-overlay-card">
                    <div style="padding: 48px;">
                        <h2 class="auth-title">Вход в систему</h2>
                        <p class="auth-subtitle">Укажите учетные данные для авторизации</p>

                        <% if (error) { %>
                            <div class="error-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                                <span><%= error %></span>
                            </div>
                        <% } %>

                        <form action="/login" method="POST" class="auth-form">
                            <div class="input-block">
                                <label for="username">Имя пользователя</label>
                                <input type="text" name="username" id="username" required autocomplete="off" placeholder="Введите ваш логин" />
                            </div>

                            <div class="input-block">
                                <label for="password">Пароль</label>
                                <input type="password" name="password" id="password" required placeholder="Введите ваш пароль" />
                            </div>

                            <button type="submit" class="btn btn-primary" style="margin-top: 12px; width: 100%;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                                </svg>
                                Войти в аккаунт
                            </button>
                        </form>

                        <p class="auth-footer">
                            Впервые здесь? <a href="/register">Создать новый аккаунт</a>
                        </p>
                    </div>
                </div>

                <div class="auth-info-card">
                    <div class="auth-info-header">
                        <h3 class="auth-info-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Панель проверки
                        </h3>
                        <div class="auth-info-text">
                            <p>Для детальной проверки возможностей программного комплекса «Игровой Атлас» вы можете:</p>
                            <p>1. <strong>Зарегистрировать</strong> свой собственный профиль с помощью кнопки ниже, чтобы проверить пользовательские функции (избранное, персональный кабинет).</p>
                            <p>2. <strong>Войти как Администратор</strong> с полными правами управления контентом и списком пользователей.</p>
                        </div>
                    </div>

                    <div class="demo-credentials">
                        <div class="credential-row">
                            <span class="credential-label">Логин</span>
                            <span class="credential-value">admin</span>
                        </div>
                        <div class="credential-row">
                            <span class="credential-label">Пароль</span>
                            <span class="credential-value">admin</span>
                        </div>
                    </div>

                    <button type="button" class="btn-autofill" onclick="fillAdminCredentials()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                        </svg>
                        Заполнить данные админа
                    </button>
                </div>
            </div>
        </main>

        <footer>
            <p>&copy; 2026 Курсовой проект по программной инженерии.</p>
        </footer>
    </div>

    <script>

        const themeToggleBtn = document.getElementById('themeToggleBtn');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-theme');
                document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }

        function fillAdminCredentials() {
            const usernameInput = document.getElementById('username');
            const passwordInput = document.getElementById('password');
            if (usernameInput && passwordInput) {
                usernameInput.value = 'admin';
                passwordInput.value = 'admin';

                usernameInput.style.borderColor = 'var(--accent)';
                passwordInput.style.borderColor = 'var(--accent)';
                usernameInput.style.boxShadow = '0 0 0 3px var(--accent-light)';
                passwordInput.style.boxShadow = '0 0 0 3px var(--accent-light)';

                setTimeout(() => {
                    usernameInput.style.borderColor = '';
                    passwordInput.style.borderColor = '';
                    usernameInput.style.boxShadow = '';
                    passwordInput.style.boxShadow = '';
                }, 1200);
            }
        }
    </script>
</body>
</html>
