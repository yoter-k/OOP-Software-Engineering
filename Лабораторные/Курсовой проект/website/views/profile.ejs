<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238e7554'%3E%3Cpath d='M19.5 6h-15A2.5 2.5 0 002 8.5v7A2.5 2.5 0 004.5 18h15a2.5 2.5 0 002.5-2.5v-7A2.5 2.5 0 0019.5 6zM8 13H6v-2h2v2zm5-1.5a1.5 1.5 0 11-1.5-1.5 1.5 1.5 0 011.5 1.5zm5 2a1.5 1.5 0 111.5-1.5 1.5 1.5 0 01-1.5 1.5z'/%3E%3C/svg%3E" />
    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <script>

        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
                document.addEventListener('DOMContentLoaded', () => {
                    document.body.classList.add('dark-theme');
                });
            }
        })();
    </script>
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="logo-section">
                <h1>Игровой<span>Атлас</span></h1>
                <p>Справочник лучших видеоигр</p>
            </div>

            <nav class="nav-menu">
                <a href="/" class="nav-link">Главная</a>
                <a href="/data" class="nav-link">Каталог</a>
                <% if (user && user.role === 'Администратор') { %>
                    <a href="/add-game" class="nav-link">Добавить игру</a>
                    <a href="/users" class="nav-link">Пользователи</a>
                <% } %>
            </nav>

            <div class="user-section">

                <button class="theme-toggle-btn" id="themeToggleBtn" title="Переключить тему">

                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>

                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m8.97-8.97h-2.25C18.18 12 18 11.82 18 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zM5.625 12H3.375C3.18 12 3 11.82 3 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zm12.06-6.435l-1.59 1.59m-9.18 9.18l-1.59 1.59m12.36 0l-1.59-1.59m-9.18-9.18l-1.59-1.59M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z" />
                    </svg>
                </button>

                <% if (user) { %>
                    <div class="user-widget" style="border-color: var(--accent); background: var(--accent-light);">
                        <div class="user-avatar" style="background: var(--accent);"><%= user.username.charAt(0).toUpperCase() %></div>
                        <div class="user-meta">
                            <span class="username"><%= user.username %></span>
                            <span class="user-role"><%= user.role %></span>
                        </div>
                    </div>
                    <a href="/logout" class="btn-logout" title="Выйти">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                        </svg>
                    </a>
                <% } else { %>
                    <a href="/login" class="nav-link">Войти</a>
                    <a href="/register" class="nav-link btn-gold">Регистрация</a>
                <% } %>
            </div>
        </header>

        <main class="main-content">
            <section class="glass-panel" style="padding: 56px;">

                <div class="profile-hero" style="margin-bottom: 36px;">
                    <div class="profile-avatar-big">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </div>
                    <div class="profile-meta-big">
                        <h2><%= user.username %></h2>
                        <span class="profile-badge">
                            <%= user.role %>
                        </span>
                    </div>
                </div>

                <%
                    let favGenre = 'Нет данных';
                    let avgCritic = '0.0';
                    let avgUser = '0.0';

                    if (favoriteGames.length > 0) {

                        const genreCounts = {};
                        let maxCount = 0;
                        favoriteGames.forEach(game => {
                            genreCounts[game.genre] = (genreCounts[game.genre] || 0) + 1;
                            if (genreCounts[game.genre] > maxCount) {
                                maxCount = genreCounts[game.genre];
                                favGenre = game.genre;
                            }
                        });

                        let totalCritic = 0;
                        let totalUser = 0;
                        favoriteGames.forEach(game => {
                            totalCritic += parseFloat(game.rating || 0);
                            totalUser += parseFloat(game.user_rating || 0);
                        });
                        avgCritic = (totalCritic / favoriteGames.length).toFixed(1);
                        avgUser = (totalUser / favoriteGames.length).toFixed(1);
                    }
                %>

                <% if (favoriteGames.length > 0) { %>

                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 48px;">
                        <div class="hero-card" style="max-width: 100%; min-width: 0; padding: 20px 24px; border: 1px solid var(--border-regular);">
                            <span class="hero-card-val" style="font-size: 1.8rem; color: var(--accent); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;"><%= favGenre %></span>
                            <span class="hero-card-lbl" style="font-size: 0.62rem; margin-top: 4px;">Любимый жанр</span>
                        </div>
                        <div class="hero-card" style="max-width: 100%; min-width: 0; padding: 20px 24px; border: 1px solid var(--border-regular);">
                            <span class="hero-card-val" style="font-size: 1.8rem;"><%= avgCritic %><span style="font-size: 0.8rem; color: var(--text-tertiary);">/10</span></span>
                            <span class="hero-card-lbl" style="font-size: 0.62rem; margin-top: 4px;">Средний балл СМИ</span>
                        </div>
                        <div class="hero-card" style="max-width: 100%; min-width: 0; padding: 20px 24px; border: 1px solid var(--border-regular);">
                            <span class="hero-card-val" style="font-size: 1.8rem; color: var(--text-primary);"><%= avgUser %><span style="font-size: 0.8rem; color: var(--text-tertiary);">/10</span></span>
                            <span class="hero-card-lbl" style="font-size: 0.62rem; margin-top: 4px;">Ваша оценка игроков</span>
                        </div>
                    </div>
                <% } %>

                <h3 class="panel-title" style="margin-bottom: 28px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
                    </svg>
                    Ваше Избранное (<%= favoriteGames.length %>)
                </h3>

                <% if (favoriteGames.length > 0) { %>
                    <div class="fav-grid">
                        <% favoriteGames.forEach(function(game) { %>
                            <article class="fav-card" id="game-card-<%= game.id %>">
                                <div class="fav-poster-frame">
                                    <img src="<%= game.image || '/public/images/default.png' %>" alt="<%= game.title %>" class="fav-poster-img" />
                                </div>
                                <div class="fav-card-body">
                                    <h4 class="fav-card-title"><%= game.title %></h4>
                                    <p class="fav-card-meta"><%= game.genre %> &middot; <%= game.release_year %></p>
                                    <div class="fav-card-footer">
                                        <div class="fav-card-rating" style="display: flex; gap: 10px; align-items: center;">
                                            <span title="Оценка критиков (СМИ)" style="display: flex; align-items: center; gap: 3px;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 24 24" style="color: var(--accent);">
                                                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                                </svg>
                                                <%= game.rating %>
                                            </span>
                                            <span title="Оценка игроков" style="display: flex; align-items: center; gap: 3px; color: var(--text-secondary);">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 24 24" style="color: var(--text-tertiary);">
                                                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                                </svg>
                                                <%= game.user_rating %>
                                            </span>
                                        </div>

                                        <button class="fav-btn active" data-game-id="<%= game.id %>" onclick="toggleFavorite(this, <%= game.id %>)" title="Удалить из избранного">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 48px 24px; border: 1px dashed var(--border-strong); border-radius: var(--radius-sm); background: var(--bg-panel);">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="color: var(--text-tertiary); margin-bottom: 16px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
                        </svg>
                        <p style="color: var(--text-secondary); font-size: 0.92rem; max-width: 320px; margin: 0 auto 20px auto; line-height: 1.6;">
                            У вас пока нет сохраненных видеоигр. Перейдите в каталог, чтобы добавить лучшие произведения в список избранного.
                        </p>
                        <a href="/data" class="btn btn-primary" style="padding: 10px 24px; font-size: 0.72rem;">Открыть Каталог</a>
                    </div>
                <% } %>
            </section>
        </main>

        <footer>
            <p>&copy; 2026 Курсовой проект по программной инженерии.</p>
        </footer>
    </div>

    <script>

        function toggleFavorite(btn, gameId) {
            fetch('/favorites/toggle', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ gameId: gameId })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    if (!data.favorited) {

                        const card = document.getElementById(`game-card-${gameId}`);
                        if (card) {
                            card.style.opacity = '0';
                            card.style.transform = 'translateY(10px)';
                            card.style.transition = 'all 0.3s cubic-bezier(0.16, 1, 0.3, 1)';
                            setTimeout(() => {
                                card.remove();

                                if (document.querySelectorAll('.fav-card').length === 0) {
                                    window.location.reload();
                                }
                            }, 300);
                        }
                    }
                }
            })
            .catch(err => console.error('Error toggling favorite:', err));
        }

        const themeToggleBtn = document.getElementById('themeToggleBtn');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-theme');
                document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }
    </script>
</body>
</html>
