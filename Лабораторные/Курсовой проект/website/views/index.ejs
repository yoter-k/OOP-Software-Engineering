<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238e7554'%3E%3Cpath d='M19.5 6h-15A2.5 2.5 0 002 8.5v7A2.5 2.5 0 004.5 18h15a2.5 2.5 0 002.5-2.5v-7A2.5 2.5 0 0019.5 6zM8 13H6v-2h2v2zm5-1.5a1.5 1.5 0 11-1.5-1.5 1.5 1.5 0 011.5 1.5zm5 2a1.5 1.5 0 111.5-1.5 1.5 1.5 0 01-1.5 1.5z'/%3E%3C/svg%3E" />
    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <script>

        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
                document.addEventListener('DOMContentLoaded', () => {
                    document.body.classList.add('dark-theme');
                });
            }
        })();
    </script>
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="logo-section">
                <h1>Игровой<span>Атлас</span></h1>
                <p>Справочник лучших видеоигр</p>
            </div>

            <nav class="nav-menu">
                <a href="/" class="nav-link" style="color: var(--accent); border-bottom: 2px solid var(--accent); border-radius: 0;">Главная</a>
                <% if (user) { %>
                    <a href="/data" class="nav-link">Каталог</a>
                    <a href="/profile" class="nav-link">Профиль</a>
                <% } %>
                <% if (user && user.role === 'Администратор') { %>
                    <a href="/add-game" class="nav-link">Добавить игру</a>
                    <a href="/users" class="nav-link">Пользователи</a>
                <% } %>
            </nav>

            <div class="user-section">

                <button class="theme-toggle-btn" id="themeToggleBtn" title="Переключить тему">

                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>

                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m8.97-8.97h-2.25C18.18 12 18 11.82 18 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zM5.625 12H3.375C3.18 12 3 11.82 3 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zm12.06-6.435l-1.59 1.59m-9.18 9.18l-1.59 1.59m12.36 0l-1.59-1.59m-9.18-9.18l-1.59-1.59M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z" />
                    </svg>
                </button>

                <% if (user) { %>
                    <div class="user-widget">
                        <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                        <div class="user-meta">
                            <span class="username"><%= user.username %></span>
                            <span class="user-role"><%= user.role %></span>
                        </div>
                    </div>
                    <a href="/logout" class="btn-logout" title="Выйти">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                        </svg>
                    </a>
                <% } else { %>
                    <a href="/login" class="nav-link">Войти</a>
                    <a href="/register" class="nav-link btn-gold">Регистрация</a>
                <% } %>
            </div>
        </header>

        <main class="main-content">

            <section class="glass-panel" style="padding: 64px 48px; border-bottom: 3px solid var(--accent);">
                <div class="hero-split">
                    <div class="hero-text-block">
                        <span class="course-badge">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                            </svg>
                            Курсовой проект 2026
                        </span>
                        <h2 class="hero-title">Интерактивный справочник <span>лучших видеоигр</span> в истории</h2>
                        <p class="hero-description">
                            «Игровой Атлас» собирает подробные спецификации и аннотации к культовым игровым произведениям. Фильтруйте списки, упорядочивайте по рейтингу критиков и находите шедевры мгновенно.
                        </p>
                        <div class="hero-grid">
                            <div class="hero-card">
                                <span class="hero-card-val accent"><%= gamesCount %></span>
                                <span class="hero-card-lbl">Игр в каталоге</span>
                            </div>
                            <div class="hero-card">
                                <span class="hero-card-val"><%= genres.length %></span>
                                <span class="hero-card-lbl">Жанров</span>
                            </div>
                        </div>
                    </div>

                    <div class="poster-showcase">
                        <div class="poster-frame">
                            <img src="/public/images/hero.png" alt="Игровой Атлас" class="poster-img" />
                        </div>
                    </div>
                </div>
            </section>

            <section class="features-asymmetric">
                <div class="asym-card">
                    <span class="asym-num">01</span>
                    <div class="asym-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75A1.875 1.875 0 0120.25 6.375v1.875A1.875 1.875 0 0118.375 10H5.625A1.875 1.875 0 013.75 8.125V6.375A1.875 1.875 0 015.625 4.5z" />
                        </svg>
                    </div>
                    <h3>Редакционный каталог</h3>
                    <p>Сдержанная просторная таблица результатов с мгновенной сортировкой, ховер-эффектами строк и бесшовным переходом к карточке игры.</p>
                </div>

                <div class="asym-card">
                    <span class="asym-num">02</span>
                    <div class="asym-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75" />
                        </svg>
                    </div>
                    <h3>Утонченные фильтры</h3>
                    <p>Боковая панель интерактивной фильтрации прямо в каталоге — настраивайте параметры и сортировку за доли секунды.</p>
                </div>

                <div class="asym-card">
                    <span class="asym-num">03</span>
                    <div class="asym-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                    </div>
                    <h3>Безопасный доступ</h3>
                    <p>Авторизация пользователей и разграничение прав доступа. Пароли надежно защищены криптографическим SHA-256 шифрованием.</p>
                </div>
            </section>

            <section class="stats-chart-section">
                <div class="chart-card">
                    <div class="chart-row">
                        <div class="chart-info-block">
                            <span class="course-badge" style="margin-bottom: 20px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
                                </svg>
                                Аналитика
                            </span>
                            <h3>Шедевры вне времени</h3>
                            <p>
                                Сравнительный анализ Топ-5 видеоигр каталога «Игровой Атлас». График сопоставляет экспертные вердикты мировых критиков с реальными оценками миллионов геймеров.
                            </p>
                            <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
                                <div style="display: flex; gap: 12px; align-items: center;">
                                    <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: var(--accent);"></span>
                                    <span style="font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Оценка экспертов</span>
                                </div>
                                <div style="display: flex; gap: 12px; align-items: center;">
                                    <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; background: var(--primary); opacity: 0.7;"></span>
                                    <span style="font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary);">Оценка пользователей</span>
                                </div>
                            </div>
                        </div>
                        <div class="svg-chart-container">
                            <%

                                const topGames = [...games].sort((a, b) => b.rating - a.rating).slice(0, 5);
                            %>
                            <svg class="stats-svg" viewBox="0 0 460 240" xmlns="http://www.w3.org/2000/svg">

                                <line x1="160" y1="40" x2="420" y2="40" class="svg-grid-line" />
                                <line x1="160" y1="80" x2="420" y2="80" class="svg-grid-line" />
                                <line x1="160" y1="120" x2="420" y2="120" class="svg-grid-line" />
                                <line x1="160" y1="160" x2="420" y2="160" class="svg-grid-line" />
                                <line x1="160" y1="200" x2="420" y2="200" class="svg-grid-line" />

                                <% topGames.forEach(function(game, index) {
                                    const y = 30 + index * 42;
                                    const maxScore = 10.0;
                                    const criticBarWidth = (game.rating / maxScore) * 200;
                                    const userBarWidth = (game.user_rating / maxScore) * 200;
                                  %>

                                    <text x="150" y="<%= y + 12 %>" text-anchor="end" class="svg-label-title"><%= game.title %></text>
                                    <text x="150" y="<%= y + 22 %>" text-anchor="end" class="svg-label-desc"><%= game.genre %></text>

                                    <rect x="160" y="<%= y + 2 %>" width="<%= criticBarWidth %>" height="7" rx="1.5" class="svg-chart-bar" style="fill: var(--accent);" title="<%= game.title %> (Критики): <%= game.rating %>">
                                        <animate attributeName="width" from="0" to="<%= criticBarWidth %>" dur="1s" fill="freeze" keySplines="0.16, 1, 0.3, 1" />
                                    </rect>

                                    <text x="<%= 160 + criticBarWidth + 6 %>" y="<%= y + 8 %>" class="svg-label-val" style="font-size: 8px; fill: var(--accent);"><%= game.rating %></text>

                                    <rect x="160" y="<%= y + 11 %>" width="<%= userBarWidth %>" height="7" rx="1.5" class="svg-chart-bar" style="fill: var(--primary); opacity: 0.7;" title="<%= game.title %> (Игроки): <%= game.user_rating %>">
                                        <animate attributeName="width" from="0" to="<%= userBarWidth %>" dur="1.1s" fill="freeze" keySplines="0.16, 1, 0.3, 1" />
                                    </rect>

                                    <text x="<%= 160 + userBarWidth + 6 %>" y="<%= y + 17 %>" class="svg-label-val" style="font-size: 8px; fill: var(--text-primary);"><%= game.user_rating %></text>
                                <% }); %>

                                <line x1="160" y1="20" x2="160" y2="220" stroke="var(--border-strong)" stroke-width="1.5" />
                            </svg>
                        </div>
                    </div>
                </div>
            </section>

            <% if (user) { %>
                <section class="glass-panel">
                    <h2 class="panel-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.637 10.637z" />
                        </svg>
                        Пульт поиска и фильтрации
                    </h2>

                    <form action="/data" method="GET" class="form-stack">
                        <div class="controls-grid">
                            <div class="input-block">
                                <label for="genre">Жанр видеоигр</label>
                                <select name="genre" id="genre">
                                    <option value="all">Все жанры каталога</option>
                                    <% genres.forEach(function(g) { %>
                                        <option value="<%= g %>"><%= g %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <div class="input-block">
                                <label for="sortBy">Критерий сортировки</label>
                                <select name="sortBy" id="sortBy">
                                    <option value="id">По идентификатору (ID)</option>
                                    <option value="title">По названию игры</option>
                                    <option value="release_year">По году выпуска</option>
                                    <option value="rating">По рейтингу критиков</option>
                                    <option value="user_rating">По оценке игроков</option>
                                    <option value="developer">По студии-разработчику</option>
                                </select>
                            </div>

                            <div class="input-block">
                                <label>Направление сортировки</label>
                                <div class="sort-tabs">
                                    <label class="sort-tab active" onclick="this.parentNode.querySelectorAll('.sort-tab').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
                                        <input type="radio" name="sortDir" value="asc" checked />
                                        <span>По возрастанию</span>
                                    </label>
                                    <label class="sort-tab" onclick="this.parentNode.querySelectorAll('.sort-tab').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
                                        <input type="radio" name="sortDir" value="desc" />
                                        <span>По убыванию</span>
                                    </label>
                                </div>
                            </div>

                            <div class="input-block">
                                <label for="gameId">Прямой переход по ID</label>
                                <input type="number" name="id" id="gameId" min="1" max="<%= gamesCount %>" placeholder="Например: 7" />
                            </div>
                        </div>

                        <div class="btn-container" style="margin-top: 12px;">
                            <button type="submit" class="btn btn-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75l-2.489-2.489m0 0a3.375 3.375 0 10-4.773-4.773 3.375 3.375 0 004.774 4.774zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Получить результаты
                            </button>
                            <a href="/data?random=true" class="btn btn-secondary">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3M3 12c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M3 12l-3 3m3-3l3 3" />
                                </svg>
                                Случайная игра
                            </a>
                        </div>
                    </form>
                </section>
            <% } else { %>
                <section class="glass-panel" style="text-align: center; padding: 64px 48px;">
                    <div style="width: 48px; height: 48px; border-radius: 4px; background: var(--accent-light); border: 1px solid var(--accent-border); color: var(--accent); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px auto;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                    </div>
                    <h3 style="font-family: var(--font-display); font-size: 1.6rem; font-weight: 500; font-style: italic; color: var(--text-primary); margin-bottom: 12px;">Доступ к справочнику ограничен</h3>
                    <p style="color: var(--text-secondary); max-width: 460px; margin: 0 auto 28px auto; font-size: 0.92rem; line-height: 1.7;">
                        Для поиска, просмотра каталога результатов и детальных спецификаций видеоигр необходимо выполнить авторизацию в системе или создать новый профиль.
                    </p>
                    <div style="display: flex; gap: 12px; justify-content: center;">
                        <a href="/login" class="btn btn-primary">Войти в профиль</a>
                        <a href="/register" class="btn btn-secondary">Зарегистрироваться</a>
                    </div>
                </section>
            <% } %>
        </main>

        <footer>
            <p>&copy; 2026 Курсовой проект по программной инженерии.</p>
        </footer>
    </div>

    <script>

        const themeToggleBtn = document.getElementById('themeToggleBtn');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-theme');
                document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }
    </script>
</body>
</html>
