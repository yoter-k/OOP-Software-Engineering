<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238e7554'%3E%3Cpath d='M19.5 6h-15A2.5 2.5 0 002 8.5v7A2.5 2.5 0 004.5 18h15a2.5 2.5 0 002.5-2.5v-7A2.5 2.5 0 0019.5 6zM8 13H6v-2h2v2zm5-1.5a1.5 1.5 0 11-1.5-1.5 1.5 1.5 0 011.5 1.5zm5 2a1.5 1.5 0 111.5-1.5 1.5 1.5 0 01-1.5 1.5z'/%3E%3C/svg%3E" />
    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <script>

        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
                document.addEventListener('DOMContentLoaded', () => {
                    document.body.classList.add('dark-theme');
                });
            }
        })();
    </script>
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="logo-section">
                <h1>Игровой<span>Атлас</span></h1>
                <p>Справочник лучших видеоигр</p>
            </div>

            <nav class="nav-menu">
                <a href="/" class="nav-link">Главная</a>
                <% if (user) { %>
                    <a href="/data" class="nav-link">Каталог</a>
                    <a href="/profile" class="nav-link">Профиль</a>
                <% } %>
                <% if (user && user.role === 'Администратор') { %>
                    <a href="/add-game" class="nav-link">Добавить игру</a>
                    <a href="/users" class="nav-link" style="color: var(--accent); border-bottom: 2px solid var(--accent); border-radius: 0;">Пользователи</a>
                <% } %>
            </nav>

            <div class="user-section">

                <button class="theme-toggle-btn" id="themeToggleBtn" title="Переключить тему">

                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>

                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m8.97-8.97h-2.25C18.18 12 18 11.82 18 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zM5.625 12H3.375C3.18 12 3 11.82 3 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zm12.06-6.435l-1.59 1.59m-9.18 9.18l-1.59 1.59m12.36 0l-1.59-1.59m-9.18-9.18l-1.59-1.59M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z" />
                    </svg>
                </button>

                <% if (user) { %>
                    <div class="user-widget">
                        <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                        <div class="user-meta">
                            <span class="username"><%= user.username %></span>
                            <span class="user-role"><%= user.role %></span>
                        </div>
                    </div>
                    <a href="/logout" class="btn-logout" title="Выйти">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                        </svg>
                    </a>
                <% } else { %>
                    <a href="/login" class="nav-link">Войти</a>
                    <a href="/register" class="nav-link btn-gold">Регистрация</a>
                <% } %>
            </div>
        </header>

        <main class="main-content">
            <section class="glass-panel" style="border-top: 3px solid var(--accent);">
                <h2 class="panel-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.109A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                    </svg>
                    Реестр зарегистрированных пользователей
                </h2>

                <p style="color: var(--text-secondary); font-size: 0.96rem; margin-bottom: 32px; line-height: 1.7; max-width: 760px;">
                    Официальный реестр учетных записей системы «Игровой Атлас». Пароли пользователей защищены с помощью криптографического алгоритма SHA-256 и не хранятся в открытом виде.
                </p>

                <div class="terminal-widgets">
                    <div class="term-widget-card">
                        <div class="term-widget-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0118 18.72zm-12 0a9.094 9.094 0 00-3.741-.479 3 3 0 004.682-2.72m-.94 3.198l-.001.031c0 .225.012.447.037.666A11.944 11.944 0 0012 21c2.17 0 4.207-.576 5.963-1.584A6.062 6.062 0 006 18.72zM12 12.75a3.75 3.75 0 110-7.5 3.75 3.75 0 010 7.5zM6 11.25a3 3 0 110-6 3 3 0 010 6zm12 0a3 3 0 110-6 3 3 0 010 6z" />
                            </svg>
                        </div>
                        <div class="term-widget-info">
                            <span class="term-widget-val"><%= usersList.length %></span>
                            <span class="term-widget-lbl">Всего аккаунтов</span>
                        </div>
                    </div>

                    <div class="term-widget-card" style="border-color: var(--accent-border);">
                        <div class="term-widget-icon" style="background: var(--accent-light); color: var(--accent); border-color: var(--accent-border);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751A11.956 11.956 0 0112 2.714z" />
                            </svg>
                        </div>
                        <div class="term-widget-info">
                            <% let adminCount = usersList.filter(u => u.role === 'Администратор').length; %>
                            <span class="term-widget-val" style="color: var(--accent);"><%= adminCount %></span>
                            <span class="term-widget-lbl">Администраторов</span>
                        </div>
                    </div>

                    <div class="term-widget-card" style="border-color: var(--green-border);">
                        <div class="term-widget-icon" style="background: var(--green-bg); color: var(--green); border-color: var(--green-border);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div class="term-widget-info">
                            <span class="term-widget-val" style="color: var(--green);"><%= usersList.length - adminCount %></span>
                            <span class="term-widget-lbl">Пользователей</span>
                        </div>
                    </div>
                </div>

                <div class="leaderboard-container">
                    <table class="leaderboard-table">
                        <thead>
                            <tr>
                                <th style="width: 80px; text-align: center;">Профиль</th>
                                <th>Имя пользователя (Логин)</th>
                                <th>Роль в системе</th>
                                <th>SHA-256 криптографический хеш пароля</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% usersList.forEach(function(u) { %>
                                <tr>
                                    <td style="text-align: center;">
                                        <div class="user-avatar" style="
                                            width: 30px;
                                            height: 30px;
                                            font-size: 0.85rem;
                                            margin: 0 auto;
                                            background: <%= u.role === 'Администратор' ? 'var(--primary)' : 'var(--bg-panel)' %>;
                                            color: <%= u.role === 'Администратор' ? '#ffffff' : 'var(--text-secondary)' %>;
                                            border: <%= u.role === 'Администратор' ? 'none' : '1px solid var(--border-regular)' %>;
                                        ">
                                            <%= u.username.charAt(0).toUpperCase() %>
                                        </div>
                                    </td>
                                    <td style="color: var(--text-primary); font-family: var(--font-display); font-weight: 700; font-size: 1.15rem;">
                                        <%= u.username %>
                                    </td>
                                    <td>
                                        <% if (u.role === 'Администратор') { %>
                                            <span class="genre-tag" style="background: var(--accent-light); color: var(--accent); border-color: var(--accent-border);">
                                                <%= u.role %>
                                            </span>
                                        <% } else { %>
                                            <span class="genre-tag">
                                                <%= u.role %>
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="crypto-cell">
                                        <%= u.passwordHash %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <div class="btn-container" style="margin-top: 32px;">
                    <a href="/" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                        </svg>
                        Вернуться на главную
                    </a>
                </div>
            </section>
        </main>

        <footer>
            <p>&copy; 2026 Курсовой проект по программной инженерии.</p>
        </footer>
    </div>

    <script>

        const themeToggleBtn = document.getElementById('themeToggleBtn');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-theme');
                document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }
    </script>
</body>
</html>
