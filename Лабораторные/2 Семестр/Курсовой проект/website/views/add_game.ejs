<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%238e7554'%3E%3Cpath d='M19.5 6h-15A2.5 2.5 0 002 8.5v7A2.5 2.5 0 004.5 18h15a2.5 2.5 0 002.5-2.5v-7A2.5 2.5 0 0019.5 6zM8 13H6v-2h2v2zm5-1.5a1.5 1.5 0 11-1.5-1.5 1.5 1.5 0 011.5 1.5zm5 2a1.5 1.5 0 111.5-1.5 1.5 1.5 0 01-1.5 1.5z'/%3E%3C/svg%3E" />
    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <script>

        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark-theme');
                document.addEventListener('DOMContentLoaded', () => {
                    document.body.classList.add('dark-theme');
                });
            }
        })();
    </script>
</head>
<body>
    <div class="wrapper">
        <header>
            <div class="logo-section">
                <h1>Игровой<span>Атлас</span></h1>
                <p>Справочник лучших видеоигр</p>
            </div>

            <nav class="nav-menu">
                <a href="/" class="nav-link">Главная</a>
                <% if (user) { %>
                    <a href="/data" class="nav-link">Каталог</a>
                    <a href="/profile" class="nav-link">Профиль</a>
                <% } %>
                <% if (user && user.role === 'Администратор') { %>
                    <a href="/add-game" class="nav-link" style="color: var(--accent); border-bottom: 2px solid var(--accent); border-radius: 0;">Добавить игру</a>
                    <a href="/users" class="nav-link">Пользователи</a>
                <% } %>
            </nav>

            <div class="user-section">

                <button class="theme-toggle-btn" id="themeToggleBtn" title="Переключить тему">

                    <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
                    </svg>

                    <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m0 13.5V21m8.97-8.97h-2.25C18.18 12 18 11.82 18 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zM5.625 12H3.375C3.18 12 3 11.82 3 11.625v-.75c0-.195.18-.375.375-.375h2.25c.195 0 .375.18.375.375v.75c0 .195-.18.375-.375.375zm12.06-6.435l-1.59 1.59m-9.18 9.18l-1.59 1.59m12.36 0l-1.59-1.59m-9.18-9.18l-1.59-1.59M12 7.5a4.5 4.5 0 110 9 4.5 4.5 0 010-9z" />
                    </svg>
                </button>

                <% if (user) { %>
                    <div class="user-widget">
                        <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
                        <div class="user-meta">
                            <span class="username"><%= user.username %></span>
                            <span class="user-role"><%= user.role %></span>
                        </div>
                    </div>
                    <a href="/logout" class="btn-logout" title="Выйти">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
                        </svg>
                    </a>
                <% } else { %>
                    <a href="/login" class="nav-link">Войти</a>
                    <a href="/register" class="nav-link btn-gold">Регистрация</a>
                <% } %>
            </div>
        </header>

        <main class="main-content">
            <div class="wizard-form-container">

                <div class="wizard-steps">
                    <div class="wizard-step active" title="Имя">1</div>
                    <div class="wizard-step active" title="Параметры">2</div>
                    <div class="wizard-step active" title="Контент">3</div>
                </div>

                <section class="glass-panel" style="border-top: 3px solid var(--accent);">
                    <h2 class="panel-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                        Внесение новой игры в реестр
                    </h2>

                    <% if (error) { %>
                        <div class="error-box">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <form action="/add-game" method="POST" class="form-stack">

                        <div class="wizard-section-divider">Шаг 1 &mdash; Идентификация</div>
                        <div class="input-block">
                            <label for="title">Название видеоигры</label>
                            <input type="text" name="title" id="title" required placeholder="Например: Red Dead Redemption 2" autocomplete="off" />
                        </div>

                        <div class="wizard-section-divider" style="margin-top: 12px;">Шаг 2 &mdash; Характеристики</div>
                        <div class="controls-grid">
                            <div class="input-block">
                                <label for="genre">Жанровое семейство</label>
                                <select name="genre" id="genre" required>
                                    <option value="RPG">RPG (Ролевая игра)</option>
                                    <option value="Action">Action (Экшен)</option>
                                    <option value="Shooter">Shooter (Шутер)</option>
                                    <option value="Strategy">Strategy (Стратегия)</option>
                                    <option value="Survival">Survival (Выживание)</option>
                                </select>
                            </div>

                            <div class="input-block">
                                <label for="developer">Студия-разработчик</label>
                                <input type="text" name="developer" id="developer" required placeholder="Например: Rockstar Games" autocomplete="off" />
                            </div>
                        </div>

                        <div class="controls-grid" style="grid-template-columns: repeat(3, 1fr);">
                            <div class="input-block">
                                <label for="release_year">Год релиза</label>
                                <input type="number" name="release_year" id="release_year" required min="1950" max="2035" placeholder="2018" />
                            </div>

                            <div class="input-block">
                                <label for="rating">СМИ (1.0 &ndash; 10.0)</label>
                                <input type="number" name="rating" id="rating" required min="1.0" max="10.0" step="0.1" placeholder="9.5" />
                            </div>

                            <div class="input-block">
                                <label for="user_rating">Игроки (1.0 &ndash; 10.0)</label>
                                <input type="number" name="user_rating" id="user_rating" required min="1.0" max="10.0" step="0.1" placeholder="9.7" />
                            </div>
                        </div>

                        <div class="wizard-section-divider" style="margin-top: 12px;">Шаг 3 &mdash; Описание & Контент</div>
                        <div class="input-block">
                            <label for="description">Краткое описание / Синопсис</label>
                            <textarea name="description" id="description" required rows="5" placeholder="Введите развернутый синопсис, основные геймплейные механики, информацию о сюжете и ключевые особенности..."></textarea>
                        </div>

                        <div class="btn-container" style="margin-top: 16px;">
                            <button type="submit" class="btn btn-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                </svg>
                                Сохранить в каталог
                            </button>
                            <a href="/" class="btn btn-secondary">Отмена</a>
                        </div>
                    </form>
                </section>
            </div>
        </main>

        <footer>
            <p>&copy; 2026 Курсовой проект по программной инженерии.</p>
        </footer>
    </div>

    <script>

        const themeToggleBtn = document.getElementById('themeToggleBtn');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const isDark = document.body.classList.toggle('dark-theme');
                document.documentElement.classList.toggle('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
            });
        }
    </script>
</body>
</html>
